package Reduction_KEM_0 {
    import oracles {
        ENCAPS() -> (Bits(400), Bits(256)),
        KEMGEN() -> Bits(100),
        DEM_ENC(k: Bits(256), m: Bits(*)) -> Bits(*),
    }

    oracle PKGEN() -> Bits(100) {
        pk <- invoke KEMGEN();
        return pk;
    }

    oracle PKENC(m0: Bits(*), m1: Bits(*)) -> (Bits(400),Bits(*)) {
        ek_k <- invoke ENCAPS();
        (ek, k) <- parse ek_k;
        c <- invoke DEM_ENC(k, m0);
        return (ek, c);
    }
}