      "index": "b0U",
      "roundness": null,
      "seed": 583847809,
      "version": 323,
      "versionNonce": 461900271,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769638355548,
      "link": null,
      "locked": false,
      "text": "The problem is for the first hybrid SETBIT(0, j, b) needs to be called on the top keys package instead of LayeredKeys. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The problem is for the first hybrid SETBIT(0, j, b) needs to be called on the top keys package instead of LayeredKeys. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
