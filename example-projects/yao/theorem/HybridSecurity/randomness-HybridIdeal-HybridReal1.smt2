            (= sample-ctr-right sample-ctr-old-right)
            (= sample-id-left (sample-id "RealLayersKeys" "LGETKEYSOUT" "rr"))
            (= sample-id-right (sample-id "KeysBot" "GETKEYSOUT" "rr"))
        )
        (and 
