package Key {
    params {
        b: Bool
    }

    state {
        k: Maybe(Bits(256))
    }

    oracle SET(k_: Bits(256)) {
        assert (k == None);
        if b {
            k__ <-$ Bits(256);
            k <- Some(k__);
        } else {
            k <- Some(k_);
        }
    }

    oracle GET() -> Bits(256) {
        assert (k != None as Bits(256));
        return Unwrap(k);
    }
}