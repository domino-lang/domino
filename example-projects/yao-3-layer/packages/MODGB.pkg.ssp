package MODGB {
    params {
        w: Integer,
        p: Integer,
        n: Integer,
    }

    import oracles {
       GBLG(l: Integer, r: Integer, op: Table((Bool,Bool),Bool), j: Integer) -> Table(Bits(p),Bool),
    }

    state {
        flag: Bool,
    }

    oracle GBL(Ci: Table(Integer, (Integer, Integer, Table((Bool,Bool),Bool)))) 
             -> Table(Integer, Table(Bits(p), Bool)) {
        assert (flag == false);
        T   <- new Table(Integer, Table(Bits(p), Bool));
        tmp <- new Table(Bits(p),Bool);
        for j: 1 <= j <= w {
            (l,r,op) <- parse Unwrap(Ci[j]);
            assert not (op[(true,  true)] == None);
            assert not (op[(true, false)] == None);
            assert not (op[(false, true)] == None);
            assert not (op[(false,false)] == None);
            tmp <- invoke GBLG(l, r, op, j);
            T[j] <- Some(tmp);
        }
        flag <- true;
        return T;
    }
}
