            (= sample-ctr-left sample-ctr-old-left)
            (= sample-ctr-right sample-ctr-old-right)
                    (= sample-id-left (sample-id "KeysBot" "GETAOUT" "r"))
                    (= sample-id-right (sample-id "KeysTop" "GETAOUT" "r"))
