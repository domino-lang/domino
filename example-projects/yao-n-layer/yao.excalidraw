    {
      "id": "_8AL9TP5pXmpBroiF22lr",
      "type": "text",
      "x": 1187.3145932661048,
      "y": 1018.9670581452683,
      "width": 1230.38330078125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
