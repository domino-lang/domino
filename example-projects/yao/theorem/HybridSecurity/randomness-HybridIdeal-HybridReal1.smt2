            (= sample-ctr-right sample-ctr-old-right)
            (= sample-id-left (sample-id "Sim" "GBLG" "rin_round_0"))
            (= sample-id-right (sample-id "LayeredSim" "LSIMGBLG" "rin_round_0"))
