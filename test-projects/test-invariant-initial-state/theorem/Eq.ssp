theorem Eq {
    instance A = A {}
    instance B = B {}

    gamehops {
        equivalence A B {
            Test: {
                randomness: simple
                invariant: [
                    theorem/invariant.smt2
                ]
                lemmas {
                    equal-aborts: []
                    invariant:    [no-abort]
                    same-output:  [no-abort]
                }
            }
        }
    }
}
