      "version": 239,
      "versionNonce": 290946837,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "2KP5Wo5Lu2ixSLhvsQLZR",
          "type": "arrow"
        }
      ],
      "updated": 1769687846949,
      "link": null,
      "locked": false,
      "text": "The problem is for the last hybrid GETKEYSIN(d, j) needs to be called on the bottom keys package instead of LayeredKeys. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The problem is for the last hybrid GETKEYSIN(d, j) needs to be called on the bottom keys package instead of LayeredKeys. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "NNrjtH7LeDiYkz02fCBMj",
      "type": "text",
      "x": 1143.2539544932517,
      "y": -72.01073785054587,
      "width": 1190.7667236328125,
      "height": 25,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
