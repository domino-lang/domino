package RedProxy {
    params {
        p: Integer
    }

    import oracles {
        GBLG(l: Integer, r: Integer, op: Table((Bool, Bool), Bool), j: Integer) -> Table(Bits(p), Bool),
    }

    oracle GBLGRED(
        l: Integer, 
        r: Integer, 
        op: Table((Bool, Bool), Bool), 
        j: Integer) -> Table(Bits(p), Bool) 
    {
        T <- invoke GBLG(l, r, op, j);
        return T;
    }
}