(define-state-relation relation-mac-table-wellformed
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((mactag Bits_n))
          (let ((entry (select H2.CR.MACinverse mactag)))
            (=> (not (is-mk-none entry))
                (= mactag (<<func-mac>> (el3-1 (maybe-get entry))
                                        (el3-2 (maybe-get entry))
                                        (el3-3 (maybe-get entry))))))))


(define-state-relation relation-prf-table-wellformed
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((prfval Bits_n))
          (let ((entry (select H2.CR.PRFinverse prfval)))
            (=> (not (is-mk-none entry))
                (= prfval (<<func-prf>> (el2-1 (maybe-get entry))
                                        (el2-2 (maybe-get entry))))))))


(define-state-relation relation-nonce-table-wellformed
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((ctr Int))
          (let ((state (select H2.KX.State ctr)))
            (=> (not (is-mk-none state))
                (let  ((u    (el11-2  (maybe-get state)))
                       (ni   (el11-7  (maybe-get state)))
                       (nr   (el11-8  (maybe-get state))))
                  (and (=> (and (not u) (not (is-mk-none ni)))
                           (= (select H2.Nonces.Nonces (maybe-get ni))
                              (mk-some true)))
                       (=> (and u (not (is-mk-none nr)))
                           (= (select H2.Nonces.Nonces (maybe-get nr))
                              (mk-some true)))))))))


(define-state-relation relation-collision-resistance
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (and
   (forall ((mactag1 Bits_n) (mactag2 Bits_n))
           (let ((entry1 (select H2.CR.MACinverse mactag1))
                 (entry2 (select H2.CR.MACinverse mactag2)))
             (=> (and (not (is-mk-none entry1))
                      (not (is-mk-none entry2)))
                 (=> (not (= mactag1 mactag2))
                     (not (= entry1 entry2))))))
   (forall ((prfval1 Bits_n) (prfval2 Bits_n))
           (let ((entry1 (select H2.CR.PRFinverse prfval1))
                 (entry2 (select H2.CR.PRFinverse prfval2)))
             (=> (and (not (is-mk-none entry1))
                      (not (is-mk-none entry2)))
                 (=> (not (= prfval1 prfval2))
                     (not (= entry1 entry2))))))))


(define-state-relation relation-keys-wellformed
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((ctr Int))
          (let ((state (select H2.KX.State ctr)))
            (=> (not (is-mk-none state))
                (let ((U    (el11-1  (maybe-get state)))
                      (V    (el11-3  (maybe-get state)))
                      (ltk  (el11-4  (maybe-get state)))
                      (k    (el11-6  (maybe-get state)))
                      (ni   (el11-7  (maybe-get state)))
                      (nr   (el11-8  (maybe-get state)))
                      (kmac (el11-9  (maybe-get state))))
                  (let ((kmac-arg (mk-tuple5 U V (maybe-get ni) (maybe-get nr) false))
                        (prf-arg  (mk-tuple5 U V (maybe-get ni) (maybe-get nr) true)))
                    (and (=> (not (is-mk-none kmac))
                             (and (not (is-mk-none k))
                                  (= kmac (mk-some (<<func-prf>> ltk kmac-arg)))
                                  (= (mk-some (mk-tuple2 ltk kmac-arg))
                                     (select H2.CR.PRFinverse (maybe-get kmac)))))
                         (=> (not (is-mk-none k))
                             (and (not (is-mk-none kmac))
                                  (= k (mk-some (<<func-prf>> ltk prf-arg)))
                                  (= (mk-some (mk-tuple2 ltk prf-arg))
                                     (select H2.CR.PRFinverse (maybe-get k))))))))))))


(define-state-relation relation-time-of-initialization
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((ctr Int))
          (let ((state (select H2.KX.State ctr)))
            (=> (not (is-mk-none state))
                (let  ((U    (el11-1  (maybe-get state)))
                       (u    (el11-2  (maybe-get state)))
                       (V    (el11-3  (maybe-get state)))
                       (kid  (el11-4  (maybe-get state)))
                       (k    (el11-6  (maybe-get state)))
                       (ni   (el11-7  (maybe-get state)))
                       (nr   (el11-8  (maybe-get state)))
                       (kmac (el11-9  (maybe-get state)))
                       (sid  (el11-10 (maybe-get state)))
                       (mess (el11-11 (maybe-get state))))
                  (and (ite u
                            (ite (> mess 0)
                                 (and (not (= sid (as mk-none (Maybe (Tuple5 Int Int Bits_n Bits_n Bits_n)))))
                                      (ite (= (select H2.KX.Fresh ctr) (mk-some true))
                                           (not (is-mk-none k))
                                           (not (is-mk-none kmac)))
                                      (not (= ni (as mk-none (Maybe Bits_n))))
                                      (not (= nr (as mk-none (Maybe Bits_n)))))
                                 (and (= sid (as mk-none (Maybe (Tuple5 Int Int Bits_n Bits_n Bits_n))))
                                      (= ni nr kmac (as mk-none (Maybe Bits_n)))))
                            (ite (= mess 0)
                                 (and (= sid (as mk-none (Maybe (Tuple5 Int Int Bits_n Bits_n Bits_n))))
                                      (= ni nr kmac (as mk-none (Maybe Bits_n))))
                                 (ite (= mess 1)
                                      (and (not (= ni (as mk-none (Maybe Bits_n))))
                                           (= nr kmac (as mk-none (Maybe Bits_n)))
                                           (= sid (as mk-none (Maybe (Tuple5 Int Int Bits_n Bits_n Bits_n)))))
                                      (and (not (= sid (as mk-none (Maybe (Tuple5 Int Int Bits_n Bits_n Bits_n)))))
                                           (ite (= (select H2.KX.Fresh ctr) (mk-some true))
                                                (not (is-mk-none k))
                                                (not (is-mk-none kmac)))
                                           (not (= ni (as mk-none (Maybe Bits_n))))
                                           (not (= nr (as mk-none (Maybe Bits_n))))))))))))))


(define-state-relation relation-time-of-acceptance
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((ctr Int))
          (let ((state (select H2.KX.State ctr)))
            (=> (not (is-mk-none state))
                (let  ((u    (el11-2  (maybe-get state)))
                       (acc  (el11-5  (maybe-get state)))
                       (mess (el11-11 (maybe-get state))))
                  (= (not (is-mk-none acc))
                     (ite u (> mess 1) (> mess 2))))))))


(define-state-relation relation-sid-wellformed
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((ctr Int))
          (let ((state (select H2.KX.State ctr)))
            (=> (not (is-mk-none state))
                (let  ((U    (el11-1  (maybe-get state)))
                       (u    (el11-2  (maybe-get state)))
                       (V    (el11-3  (maybe-get state)))
                       (kid  (el11-4  (maybe-get state)))
                       (k    (el11-6  (maybe-get state)))
                       (ni   (el11-7  (maybe-get state)))
                       (nr   (el11-8  (maybe-get state)))
                       (kmac (el11-9  (maybe-get state)))
                       (sid  (el11-10 (maybe-get state)))
                       (mess (el11-11 (maybe-get state))))
                  (=> (not (is-mk-none sid))
                      (and (= sid (mk-some (mk-tuple5 U V (maybe-get ni) (maybe-get nr)
                                                      (<<func-mac>> (maybe-get kmac) (maybe-get nr) 2))))
                           (not (is-mk-none (select H2.CR.MACinverse (el5-5 (maybe-get sid)))))
                           (= kmac (mk-some (el3-1 (maybe-get (select H2.CR.MACinverse (el5-5 (maybe-get sid))))))))))))))


(define-state-relation relation-own-nonce-unique
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
  (forall ((ctr1 Int) (ctr2 Int))
          (let ((state1 (select H2.KX.State ctr1))
                (state2 (select H2.KX.State ctr2)))
            (=> (and (not (is-mk-none state1))
                     (not (is-mk-none state2)))
                (let ((u1    (el11-2  (maybe-get state1)))
                      (ni1   (el11-7  (maybe-get state1)))
                      (nr1   (el11-8  (maybe-get state1)))
                      (u2    (el11-2  (maybe-get state2)))
                      (ni2   (el11-7  (maybe-get state2)))
                      (nr2   (el11-8  (maybe-get state2))))
                  (let ((nonce1 (ite u1 nr1 ni1))
                        (nonce2 (ite u2 nr2 ni2)))
                    (=> (and (not (= ctr1 ctr2))
                             (not (is-mk-none nonce1)))
                        (not (= nonce1 nonce2)))))))))


(define-state-relation relation-session-matching
    ((H2 <GameState_H2_<$<!n!>$>>)
     (H3 <GameState_H3_<$<!n!>$>>))
    (forall ((ctr1 Int) (ctr2 Int))
          (let ((state1 (select H2.KX.State ctr1))
                (state2 (select H2.KX.State ctr2)))
            (=> (and (not (is-mk-none state1))
                     (not (is-mk-none state2)))
                (let ((ltk1  (el11-4  (maybe-get state1)))
                      (acc1  (el11-5  (maybe-get state1)))
                      (k1    (el11-6  (maybe-get state1)))
                      (ni1   (el11-7  (maybe-get state1)))
                      (nr1   (el11-8  (maybe-get state1)))
                      (kmac1 (el11-9  (maybe-get state1)))
                      (sid1  (el11-10 (maybe-get state1)))
                      (ltk2  (el11-4  (maybe-get state2)))
                      (acc2  (el11-5  (maybe-get state2)))
                      (k2    (el11-6  (maybe-get state2)))
                      (ni2   (el11-7  (maybe-get state2)))
                      (nr2   (el11-8  (maybe-get state2)))
                      (kmac2 (el11-9  (maybe-get state2)))
                      (sid2  (el11-10 (maybe-get state2))))
                  (and (= (and (not (is-mk-none k1))
                               (= k1 k2))
                          (and (not (is-mk-none kmac1))
                               (= kmac1 kmac2)))
                       (=> (and (= (mk-some true) acc1 acc2)
                                (= sid1 sid2))
                           (and (= k1 k2)))
                       (=> (and (not (is-mk-none k1))
                                (= k1 k2))
                           (and (= ni1 ni2)
                                (= nr1 nr2)
                                (= ltk1 ltk2)))))))))


(define-state-relation invariant
    ((state-H2 <GameState_H2_<$<!n!>$>>)
     (state-H3 <GameState_H3_<$<!n!>$>>))

  (and (= state-H2.KX.LTK       state-H3.KX.LTK)
       (= state-H2.KX.H         state-H3.KX.H)
       (= state-H2.KX.Fresh     state-H3.KX.Fresh)
       (= state-H2.KX.First     state-H3.KX.First)
       (= state-H2.KX.Second    state-H3.KX.Second)
       (= state-H2.KX.State     state-H3.KX.State)
       (= state-H2.KX.RevTested state-H3.KX.RevTested)
       (= state-H2.KX.ctr_      state-H3.KX.ctr_)
       (= state-H2.KX.kid_      state-H3.KX.kid_)

       (= state-H2.Nonces state-H3.Nonces)
       (= state-H2.CR     state-H3.CR)

       (relation-mac-table-wellformed    state-H2 state-H3)
       (relation-prf-table-wellformed    state-H2 state-H3)
       (relation-nonce-table-wellformed  state-H2 state-H3)

       (relation-collision-resistance    state-H2 state-H3)
       (relation-keys-wellformed         state-H2 state-H3)
       (relation-time-of-initialization  state-H2 state-H3)
       (relation-time-of-acceptance      state-H2 state-H3)
       (relation-sid-wellformed          state-H2 state-H3)
       (relation-own-nonce-unique        state-H2 state-H3)
       (relation-session-matching        state-H2 state-H3)))
