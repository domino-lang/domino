package GBLG3 {
    params {
        p: Integer
    }

    import oracles {
        GBLG(l: Integer, r: Integer, op: Table((Bool, Bool), Bool), j: Integer) 
            -> Table(Bits(p), Bool),
    }

    oracle GBLG3(
        l: Integer, 
        r: Integer, 
        op: Table((Bool, Bool), Bool), 
        j: Integer
    ) -> Table(Bits(p), Bool) {
        g <- invoke GBLG(l, r, op, j);
        return g;
    }
}