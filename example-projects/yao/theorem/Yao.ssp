theorem Yao {
    const n: Integer;
    const m: Integer;
    const p: Integer;
    const d: Integer;
    const w: Integer;
    const encn: fn Bits(n),Bits(n),Bits(n) -> Bits(m);
    const encm: fn Bits(n),Bits(m),Bits(n) -> Bits(p);

    instance CoreReal = CoreReal {
        params {
            n: n,
            m: m,
            p: p,
            d: d,
            encm: encm,
            encn: encn,
        }
    }

    instance CoreIdeal = CoreIdeal {
        params {
            n: n,
            m: m,
            p: p,
            d: d,
            encm: encm,
            encn: encn,
        }
    }

    instance YaoReal = YaoReal {
        params {
            n: n,
            m: m,
            p: p,
            d: d,
            w: w,
            encm: encm,
            encn: encn
        }
    }

    instance YaoIdeal = YaoIdeal {
        params {
            n: n,
            m: m,
            p: p,
            d: d,
            w: w,
            encm: encm,
            encn: encn
        }
    }

    assumptions {
        HybridSecurity: CoreReal ~ CoreIdeal
    }

    gamehops {
        reduction YaoReal YaoIdeal {
            assumption HybridSecurity

            map CoreReal YaoReal {
                Keys: Keys
                Enc: Enc
                Gate: Gate
                LayerMap: LayerMap
            }

            map CoreIdeal YaoIdeal {
                Keys: Keys
                Lev: Lev
                Sim: Sim
                LayerMap: LayerMap
            }
        }
    }
    
    propositions {
        Yao: YaoReal ~ YaoIdeal
    }
}
